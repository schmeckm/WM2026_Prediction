# Portainer / Docker production — copy to `.env` in project root (never commit).
# Local development uses backend/.env instead — see backend/.env.example
#
# MANDATORY (stack fails without these):
#   JWT_SECRET, DB_PASSWORD
#
# REQUIRED for public deployment (wrong values = broken login/API):
#   APP_URL, CORS_ORIGIN, FRONTEND_PORT
#
# See README.md and docs/DEPLOY-GITHUB-PORTAINER.md for full variable reference.

# --- App / Netzwerk (dein Server) ---
# Google OAuth akzeptiert keine Raw-IP – sslip.io nutzen (zeigt auf dieselbe IP).
FRONTEND_PORT=8081
CORS_ORIGIN=http://136-244-90-128.sslip.io:8081
APP_URL=http://136-244-90-128.sslip.io:8081

# --- Google SSO (beide Werte nötig, sonst /api/auth/providers → {"google":false}) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://136-244-90-128.sslip.io:8081/api/auth/google/callback

# --- Sicherheit ---
JWT_SECRET=change-me-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
TRUST_PROXY=true

# --- Rate Limits (optional, pro User wenn eingeloggt) ---
# RATE_LIMIT_ENABLED=false
# API_RATE_LIMIT_MAX=1200
# AUTH_RATE_LIMIT_MAX=100
# LEADERBOARD_RATE_LIMIT_MAX=300
# PUBLIC_READ_RATE_LIMIT_MAX=300
# DISPLAY_RATE_LIMIT_MAX=60

# --- GitHub (User-Feedback → Issues im Repo) ---
# Personal Access Token mit repo/Issues-Rechten
GITHUB_TOKEN=
GITHUB_REPO=schmeckm/WM2026_Prediction
# Optional: kommagetrennte Labels, z. B. feedback,from-portal
GITHUB_FEEDBACK_LABELS=feedback

# --- PostgreSQL (docker-compose.prod.yml) ---
DB_NAME=wm2026
DB_USER=postgres
DB_PASSWORD=change-me-strong-db-password

# --- Registrierung ---
OPEN_REGISTRATION=true

# --- Erster Admin (optional, nur wenn noch kein Admin existiert) ---
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# --- Football API (football-data.org) ---
FOOTBALL_API_PROVIDER=football-data
FOOTBALL_API_BASE_URL=https://api.football-data.org/v4
FOOTBALL_API_KEY=
FOOTBALL_API_COMPETITION_ID=WC
FOOTBALL_API_COMPETITION_NUMERIC_ID=2000
FOOTBALL_API_SEASON=2026
FOOTBALL_API_TIMEZONE=Europe/Zurich
FOOTBALL_API_SYNC_ENABLED=true
FOOTBALL_API_RESULT_SYNC_ENABLED=true

# --- YouTube (Highlight-Vorschläge + optional Auto-Fill) ---
YOUTUBE_API_KEY=
YOUTUBE_REGION_CODE=CH
YOUTUBE_SKIP_CHANNEL_KEYWORDS=fifa
YOUTUBE_SKIP_CHANNEL_IDS=
AUTO_HIGHLIGHTS_ENABLED=false
AUTO_HIGHLIGHTS_CRON=15 */2 * * *
AUTO_HIGHLIGHTS_LOOKBACK_HOURS=72
AUTO_HIGHLIGHTS_MAX_UPDATES=5
AUTO_HIGHLIGHTS_TOURNAMENT_ONLY=true

# --- KI / OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_FEATURES_ENABLED=true
AI_CACHE_ENABLED=true
AI_MAX_TOKENS=800
AI_TEMPERATURE=0.4
AI_ADMIN_FEATURES_ENABLED=true
AI_USER_COACH_ENABLED=true
AI_MATCH_PREVIEW_ENABLED=true
AI_LEADERBOARD_COMMENTARY_ENABLED=true

# --- E-Mail / SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="WM Tippspiel <deine-email@gmail.com>"

# --- TheSportsDB (Spielerbilder + Stadion/Ort für WM-Spiele) ---
PLAYER_IMAGE_ENABLED=true
PLAYER_IMAGE_THESPORTSDB_API_KEY=123
THESPORTSDB_VENUE_ENRICHMENT_ENABLED=true
THESPORTSDB_LEAGUE_ID=4429
THESPORTSDB_SEASON=2026

# --- Sentry (optional, Fehlerüberwachung) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production

# Nicht für Portainer/Postgres nutzen (nur lokale Dev):
# DB_PATH=./database/wm2026.sqlite
# DB_SYNC_ALTER=false
# PORT=3000
