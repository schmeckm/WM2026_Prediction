# =============================================================================
# WM 2026 Prediction Game — Environment template (Production / Portainer)
# =============================================================================
#
# Usage:
#   cp .env.example .env
#   # fill in values, then deploy with docker-compose.prod.yml
#
# Never commit `.env` to Git.
#
# Legend:
#   [REQUIRED]     — stack will not start without this
#   [PUBLIC URL]   — required for a working deployment on the internet
#   [RECOMMENDED]  — strongly advised in production
#   [OPTIONAL]     — feature works without it (fallback / disabled)
#
# Full reference: README.md · docs/DEPLOY-GITHUB-PORTAINER.md
# Local dev (SQLite): use backend/.env.example instead
# =============================================================================

# --- [PUBLIC URL] App & network ------------------------------------------------
# Use a real hostname for Google SSO (no raw IP). Example: your-domain.com or sslip.io
FRONTEND_PORT=8080
APP_URL=https://tippspiel.example.com
CORS_ORIGIN=https://tippspiel.example.com

# --- [REQUIRED] Security -------------------------------------------------------
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_EXPIRES_IN=7d

# --- [REQUIRED] PostgreSQL (docker-compose.prod.yml) ---------------------------
DB_NAME=wm2026
DB_USER=postgres
DB_PASSWORD=change-me-strong-db-password

# --- [RECOMMENDED] Reverse proxy -----------------------------------------------
TRUST_PROXY=true

# --- [OPTIONAL] Registration & first admin -------------------------------------
OPEN_REGISTRATION=true
# Only used when no admin exists yet:
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# --- [OPTIONAL] Google SSO -----------------------------------------------------
# Both GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET required for SSO
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://tippspiel.example.com/api/auth/google/callback

# --- [OPTIONAL] Football API — fixtures, live scores, results (server-side) ----
# Provider: football-data.org (recommended). Without key: CSV import + manual results.
FOOTBALL_API_PROVIDER=football-data
FOOTBALL_API_BASE_URL=https://api.football-data.org/v4
FOOTBALL_API_KEY=
FOOTBALL_API_COMPETITION_ID=WC
FOOTBALL_API_COMPETITION_NUMERIC_ID=2000
FOOTBALL_API_SEASON=2026
FOOTBALL_API_TIMEZONE=Europe/Zurich
FOOTBALL_API_SYNC_ENABLED=true
FOOTBALL_API_RESULT_SYNC_ENABLED=true

# --- [OPTIONAL] The Odds API — market win/draw/loss probabilities --------------
# Register at https://the-odds-api.com — insights only, does not affect scoring.
ODDS_API_KEY=
ODDS_API_SPORT_KEY=soccer_fifa_world_cup
ODDS_API_REGIONS=eu
ODDS_API_MARKETS=h2h
ODDS_API_ODDS_FORMAT=decimal
ODDS_API_ENABLED=true
ODDS_API_CRON=0 6 * * *
ODDS_API_ROLLING_CRON=0 * * * *

# --- [OPTIONAL] YouTube — match highlight suggestions --------------------------
YOUTUBE_API_KEY=
YOUTUBE_REGION_CODE=CH
YOUTUBE_SKIP_CHANNEL_KEYWORDS=fifa
YOUTUBE_SKIP_CHANNEL_IDS=
AUTO_HIGHLIGHTS_ENABLED=false
AUTO_HIGHLIGHTS_CRON=15 */2 * * *
AUTO_HIGHLIGHTS_LOOKBACK_HOURS=72
AUTO_HIGHLIGHTS_MAX_UPDATES=5
AUTO_HIGHLIGHTS_TOURNAMENT_ONLY=true

# --- [OPTIONAL] OpenAI — AI coach, previews, admin assistant -------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_FEATURES_ENABLED=true
AI_CACHE_ENABLED=true
AI_MAX_TOKENS=800
AI_TEMPERATURE=0.4
AI_ADMIN_FEATURES_ENABLED=true
AI_USER_COACH_ENABLED=true
AI_MATCH_PREVIEW_ENABLED=true
AI_LEADERBOARD_COMMENTARY_ENABLED=true

# --- [OPTIONAL] Email (SMTP) ---------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="WM Tippspiel <noreply@example.com>"

# --- [OPTIONAL] TheSportsDB — player images, stadium enrichment ----------------
PLAYER_IMAGE_ENABLED=true
PLAYER_IMAGE_THESPORTSDB_API_KEY=123
THESPORTSDB_VENUE_ENRICHMENT_ENABLED=true
THESPORTSDB_LEAGUE_ID=4429
THESPORTSDB_SEASON=2026

# --- [OPTIONAL] GitHub — portal feedback → Issues ------------------------------
GITHUB_TOKEN=
GITHUB_REPO=schmeckm/WM2026_Prediction
GITHUB_FEEDBACK_LABELS=feedback

# --- [OPTIONAL] Rate limits (per authenticated user) ---------------------------
# RATE_LIMIT_ENABLED=false
# API_RATE_LIMIT_MAX=1200
# AUTH_RATE_LIMIT_MAX=100
# LEADERBOARD_RATE_LIMIT_MAX=300
# PUBLIC_READ_RATE_LIMIT_MAX=300
# DISPLAY_RATE_LIMIT_MAX=60

# --- [OPTIONAL] Sentry — error monitoring --------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production

# --- Docker stack defaults (usually leave unchanged) ---------------------------
# REDIS_URL=redis://redis:6379
# BACKEND_IMAGE=ghcr.io/schmeckm/wm2026_prediction-backend:latest
# FRONTEND_IMAGE=ghcr.io/schmeckm/wm2026_prediction-frontend:latest
